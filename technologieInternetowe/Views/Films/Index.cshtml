@model IEnumerable<technologieInternetowe.Models.Film>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-camera-video me-2"></i>Filmy</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Dodaj film
    </a>
</div>

<form method="get" class="mb-4">
    <div class="input-group" style="max-width:400px">
        <input type="text" name="search" class="form-control" placeholder="Szukaj tytułu lub reżysera..." value="@ViewData["Search"]" />
        <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
        @if (!string.IsNullOrEmpty(ViewData["Search"]?.ToString()))
        {
            <a asp-action="Index" class="btn btn-outline-danger"><i class="bi bi-x"></i></a>
        }
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Brak filmów do wyświetlenia.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var film in Model)
        {
            <div class="col">
                <div class="card film-card h-100 shadow-sm">
                    @if (!string.IsNullOrWhiteSpace(film.CoverImageUrl))
                    {
                        <img src="@film.CoverImageUrl" class="card-img-top" alt="Okładka: @film.Title" style="height: 280px; object-fit: cover;" />
                    }
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">@film.Title</h5>
                            <span class="badge bg-primary ms-2">@film.Category?.Name</span>
                        </div>
                        <p class="text-muted small mb-1"><i class="bi bi-person me-1"></i>@film.Director</p>
                        <p class="card-text text-secondary small">@film.Desc</p>
                        @if (film.Price.HasValue)
                        {
                            <p class="fw-semibold text-success"><i class="bi bi-tag me-1"></i>@film.Price?.ToString("C")</p>
                        }
                    </div>
                    <div class="card-footer bg-transparent d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@film.FilmId" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-eye me-1"></i>Szczegóły
                        </a>
                        <a asp-action="Edit" asp-route-id="@film.FilmId" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-pencil me-1"></i>Edytuj
                        </a>
                        <a asp-action="Delete" asp-route-id="@film.FilmId" class="btn btn-sm btn-outline-danger ms-auto">
                            <i class="bi bi-trash me-1"></i>Usuń
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
