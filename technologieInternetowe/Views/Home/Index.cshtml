@model technologieInternetowe.Models.HomeDashboardViewModel

<section class="home-hero mb-4">
    <div>
        <h1 class="display-6 fw-bold mb-2">Witaj w CineBase</h1>
        <p class="text-secondary mb-0">Zarządzaj filmami i kategoriami w jednym miejscu.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a asp-controller="Films" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Dodaj film
        </a>
        <a asp-controller="Category" asp-action="Create" class="btn btn-outline-primary">
            <i class="bi bi-folder-plus me-1"></i>Dodaj kategorię
        </a>
    </div>
</section>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card stat-card h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small">Liczba filmów</div>
                    <div class="display-6 fw-semibold mb-0">@Model.FilmsCount</div>
                </div>
                <i class="bi bi-camera-video fs-1 text-primary"></i>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card stat-card h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small">Liczba kategorii</div>
                    <div class="display-6 fw-semibold mb-0">@Model.CategoriesCount</div>
                </div>
                <i class="bi bi-tags fs-1 text-warning"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-8">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-stars me-2"></i>Najnowsze filmy</h5>
                <a asp-controller="Films" asp-action="Index" class="btn btn-sm btn-outline-primary">Zobacz wszystkie</a>
            </div>
            <div class="card-body">
                @if (!Model.LatestFilms.Any())
                {
                    <div class="alert alert-info mb-0">Brak filmów. Dodaj pierwszy rekord.</div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var film in Model.LatestFilms)
                        {
                            <a asp-controller="Films" asp-action="Details" asp-route-id="@film.FilmId" class="list-group-item list-group-item-action px-0 d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(film.CoverImageUrl))
                                    {
                                        <img src="@film.CoverImageUrl" alt="Okładka @film.Title" class="rounded me-3 shadow-sm" style="width: 50px; height: 75px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded me-3 d-flex justify-content-center align-items-center text-secondary border shadow-sm" style="width: 50px; height: 75px;">
                                            <i class="bi bi-film fs-4"></i>
                                        </div>
                                    }
                                    <div>
                                        <div class="fw-semibold">@film.Title</div>
                                        <small class="text-muted">@film.Director</small>
                                    </div>
                                </div>
                                <span class="badge bg-light text-dark border">@film.Category?.Name</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-collection me-2"></i>Kategorie</h5>
            </div>
            <div class="card-body">
                @if (!Model.Categories.Any())
                {
                    <div class="alert alert-info mb-0">Brak kategorii.</div>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var category in Model.Categories)
                        {
                            <a asp-controller="Category" asp-action="Details" asp-route-id="@category.Id" class="badge rounded-pill text-bg-light border text-decoration-none p-2">
                                @category.Name
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
