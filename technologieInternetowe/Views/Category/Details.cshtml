@model technologieInternetowe.Models.Category

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h4 class="mb-0">
                    <i class="bi bi-folder me-2 text-warning"></i>@Model.Name
                </h4>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Nazwa</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">Opis</dt>
                    <dd class="col-sm-8">@Model.Description</dd>

                    <dt class="col-sm-4">Liczba filmów</dt>
                    <dd class="col-sm-8">@Model.Films?.Count()</dd>
                </dl>
            </div>
            <div class="card-footer bg-transparent d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                    <i class="bi bi-pencil me-1"></i>Edytuj
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                    <i class="bi bi-trash me-1"></i>Usuń
                </a>
                <a asp-action="Index" class="btn btn-outline-primary ms-auto">
                    <i class="bi bi-arrow-left me-1"></i>Wróć
                </a>
            </div>
        </div>

        @if (Model.Films != null && Model.Films.Any())
        {
            <h5 class="mb-3"><i class="bi bi-camera-video me-2"></i>Filmy w tej kategorii</h5>
            <div class="list-group">
                @foreach (var film in Model.Films)
                {
                    <a asp-controller="Films" asp-action="Details" asp-route-id="@film.FilmId"
                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@film.Title</strong>
                            <span class="text-muted small ms-2">@film.Director</span>
                        </div>
                        @if (film.Price.HasValue)
                        {
                            <span class="badge bg-success">@film.Price.Value.ToString("C")</span>
                        }
                    </a>
                }
            </div>
        }
    </div>
</div>
