@model IEnumerable<technologieInternetowe.Models.Category>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-tags me-2"></i>Kategorie</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-folder-plus me-1"></i>Dodaj kategorię
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Brak kategorii do wyświetlenia.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var category in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5 class="card-title mb-0">
                                <i class="bi bi-folder me-1 text-warning"></i>@category.Name
                            </h5>
                            <span class="badge bg-secondary">@category.Films?.Count() filmów</span>
                        </div>
                        <p class="card-text text-muted small">@category.Description</p>
                    </div>
                    <div class="card-footer bg-transparent d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@category.Id" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-eye me-1"></i>Szczegóły
                        </a>
                        <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-pencil me-1"></i>Edytuj
                        </a>
                        <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-sm btn-outline-danger ms-auto">
                            <i class="bi bi-trash me-1"></i>Usuń
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
